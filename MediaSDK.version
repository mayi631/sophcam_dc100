MAJOR_VERSION := 0
MINOR_VERSION := 1
BUILD_NUMBER  := 8

BUILD_FLAG := -DVERSION_BUILD_DATE=\""$(shell LANG=en_us_88591; date)"\" \
		-DVERSION_BUILD_MACHINE=\""$(shell echo `whoami`@`hostname`)"\" \
		-DVERSION_BUILD_REVISION=\"${MAJOR_VERSION}.${MINOR_VERSION}.${BUILD_NUMBER}\"

CFLAGS += $(BUILD_FLAG)
CXXFLAGS += $(BUILD_FLAG)

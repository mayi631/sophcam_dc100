# 编译输出目录
out/

# IDE配置
.vscode/
.idea/

# 编译生成的库文件(排除comps_install预编译库)
**/*.a
**/*.so
!components/comps_install/**/*

# 编译生成的目标文件
*.o
*.d
*.cmd
built-in.o

# 特定编译产物目录
app_services/lib/
app_services/obj/
applications/*/lib/
applications/*/obj/
components/*/lib/
components/*/obj/

# UI编译产物（仅忽略turnkey生成的build目录）
applications/dashcam/ui/*/turnkey/build/
applications/dashcam/ui/*/build/

# OSS第三方库编译产物
oss/awtkcode/awtk/build/
oss/awtkcode/awtk-linux-fb/build/
oss/ffmpeg/build/
oss/ffmpeg/install/
oss/lvgl/install/
oss/lvgl/build/
oss/csi2d/build/
oss/thttpd/build/

# 可执行文件(忽略编译输出,保留模板和配置文件)
**/out/bin/*
**/app_services/bin/*
**/applications/*/bin/*
!**/bin/.gitkeep

# 安装目录
install/
**/install/arm-none-linux-musleabihf/

# 构建标记
*.stamp
.sconsign.dblite
.sconsign.dblite2

# 日志文件
*.log

# 临时文件
*~
.*.swp
.DS_Store
Thumbs.db

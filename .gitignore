# 编译输出目录
out/

# IDE配置
.vscode/
.idea/

# 编译生成的库文件(只忽略真正编译生成的)
out/**/*.a
out/**/*.so
components/AIsdk/.deps/
components/*/build/
oss/awtkcode/awtk-linux-fb/build/
oss/ffmpeg/build/
oss/lvgl/build/
oss/csi2d/build/
oss/thttpd/build/

# 编译生成的目标文件
*.o
*.d
*.cmd
built-in.o

# 特定编译产物目录
app_services/obj/
applications/*/obj/
components/*/obj/

# UI编译产物（仅忽略turnkey生成的build目录）
applications/dashcam/ui/*/turnkey/build/
applications/dashcam/ui/*/build/

# OSS第三方库编译产物
oss/awtkcode/awtk/build/
oss/ffmpeg/install/
oss/csi2d/build/
oss/thttpd/build/
oss/lvgl/install/

# 应用和服务的编译库
app_services/lib/
applications/*/lib/

# 可执行文件(忽略编译输出,保留模板和配置文件)
**/out/bin/*
**/app_services/bin/*
**/applications/*/bin/*
!**/bin/.gitkeep



# 构建标记
*.stamp
.sconsign.dblite
.sconsign.dblite2

# 日志文件
*.log

# 临时文件
*~
.*.swp
.DS_Store
Thumbs.db

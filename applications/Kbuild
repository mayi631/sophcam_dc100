#
# Kbuild for framework
#

ifeq ($(CONFIG_APP_DASHCAM), y)
	KBUILD_DEFINES += -DPDT_DASHCAM
	CFG_PDT := dashcam
endif



ifeq ($(CONFIG_RESET_MODE_AHD_HOTPLUG), y)
	KBUILD_DEFINES += -DRESET_MODE_AHD_HOTPLUG_ON
endif

ifeq ($(CONFIG_LOAD_PARAM_FROM_FILE), y)
	KBUILD_DEFINES += -DLOAD_PARAM_FROM_FILE
endif

ifeq ($(CONFIG_CARRECORDER), y)
	CFG_PDT_SUB := carrecorder
	ifeq ($(CONFIG_CARRECORDER_TURNKEY), y)
		UI_PACKET := turnkey
	endif
else ifeq ($(CONFIG_REARVIEW), y)
	CFG_PDT_SUB := rearview
	ifeq ($(CONFIG_REARVIEW_TURNKEY), y)
		UI_PACKET := turnkey
	endif
else ifeq ($(CONFIG_AICAMERA), y)
	CFG_PDT_SUB := aicamera
	ifeq ($(CONFIG_AICAMERA_TURNKEY), y)
		UI_PACKET := turnkey
	else ifeq ($(CONFIG_AICAMERA_DC309), y)
		UI_PACKET := dc309
	endif
else ifeq ($(CONFIG_NONESCREEN), y)
	CFG_PDT_SUB := nonescreen
	UI_PACKET := turnkey
endif

ifeq ($(CONFIG_NETPROTOCOL_XML), y)
	KBUILD_DEFINES += -DNETPROTOCOL_XML
else ifeq ($(CONFIG_NETPROTOCOL_CGI), y)
	KBUILD_DEFINES += -DNETPROTOCOL_CGI
else ifeq ($(CONFIG_NETPROTOCOL_CJSON), y)
	KBUILD_DEFINES += -DNETPROTOCOL_CJSON
endif

INI_PDT :=$(CONFIG_INIPATH)

UI_WIDTH     := $(shell echo $(CONFIG_UI_WIDTH))
UI_HEIGHT    := $(shell echo $(CONFIG_UI_HEIGHT))
UI_RESPATH    := \"$(shell echo $(CONFIG_UI_RESPATH))\"

KBUILD_DEFINES += -DLCD_UI_WIDTH=$(UI_WIDTH)
KBUILD_DEFINES += -DLCD_UI_HEIGHT=$(UI_HEIGHT)
KBUILD_DEFINES += -DLCD_UI_RESPATH=$(UI_RESPATH)

ifeq ($(CONFIG_FB_DUAL_BUFFER), y)
	KBUILD_DEFINES += -DFB_DUAL_BUFFER
endif

ifeq ($(CONFIG_FB_ARGB8888), y)
	KBUILD_DEFINES += -DFB_ARGB8888
endif

ifeq ($(CONFIG_FB_ARGB4444), y)
	KBUILD_DEFINES += -DFB_ARGB4444
endif

ifeq ($(CONFIG_FB_ARGB1555), y)
	KBUILD_DEFINES += -DFB_ARGB1555
endif

ifeq ($(CONFIG_FB_PIX_DEPTH_16), y)
	KBUILD_DEFINES += -DFB_PIX_DEPTH_16
endif

ifeq ($(CONFIG_FB_PIX_DEPTH_32), y)
	KBUILD_DEFINES += -DFB_PIX_DEPTH_32
endif

ifeq ($(CONFIG_APPLICATION_NET), y)
	KBUILD_DEFINES += -DAPPLICATION_NET_ON
endif

ifeq ($(CONFIG_ADC), y)
	KBUILD_DEFINES += -DADC_ON
endif

ifeq ($(CONFIG_LOG_DEBUG), y)
	KBUILD_DEFINES += -DBUILT_LOG_LEVEL=CVI_LOG_DEBUG
else ifeq ($(CONFIG_LOG_INFO), y)
	KBUILD_DEFINES += -DBUILT_LOG_LEVEL=CVI_LOG_INFO
else ifeq ($(CONFIG_LOG_WARNING), y)
	KBUILD_DEFINES += -DBUILT_LOG_LEVEL=CVI_LOG_WARNING
else ifeq ($(CONFIG_LOG_ERROR), y)
	KBUILD_DEFINES += -DBUILT_LOG_LEVEL=CVI_LOG_ERROR
else ifeq ($(CONFIG_LOG_FATAL), y)
	KBUILD_DEFINES += -DBUILT_LOG_LEVEL=CVI_LOG_FATAL
else ifeq ($(CONFIG_LOG_NONE), y)
	KBUILD_DEFINES += -DBUILT_LOG_LEVEL=CVI_LOG_NONE
endif

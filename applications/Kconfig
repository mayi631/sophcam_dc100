	Say Y if you want to enable Reset Mode After AHD Hotplug.
endmenu

menu "ISP Configuration"
config ENABLE_ISP_PQ_TOOL
	bool "Enable ISP PQ Tool"
	select SERVICES_RTSP
	help
	  Say Y if you want to enable ISP PQ Tool.
endmenu

menu "APP Param Configuration"
    config LOAD_PARAM_FROM_FILE
	bool "Load Param From File"
	help
		Say Y if you want to load param from bin file.

	config LOAD_PARAM_FROM_FLASH
		bool "Load Param From Flash"
		help
			Say Y if you want to load param from flash.

	config INIPATH
		string "Ini Path"
		default "cadv_turnkey"
		help
			Please set the ini path folder name.
endmenu


	prompt "FB pixdepth"
	default FB_PIX_DEPTH_16
	config FB_PIX_DEPTH_16
		bool "FB_PIX_DEPTH_16"
	config FB_PIX_DEPTH_32
		bool "FB_PIX_DEPTH_32"
endchoice

choice
	prompt "FB pixformat"
	default FB_ARGB4444
	config FB_ARGB4444
		bool "FB_ARGB4444"
		depends on FB_PIX_DEPTH_16
	config FB_ARGB1555
		bool "FB_ARGB1555"
		depends on FB_PIX_DEPTH_16
	config FB_ARGB8888
		bool "FB_ARGB8888"
		depends on FB_PIX_DEPTH_32
endchoice

endmenu
endif

